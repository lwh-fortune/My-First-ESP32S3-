/* pages/index/index.wxss */

.container {
  padding: 20rpx 40rpx;
  padding-top: 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background-color: #f8f8f8;
  border-radius: 0;
  line-height: 1.6;
}

.header { text-align: center; margin: 40rpx 0; font-size: 36rpx; font-weight: bold; color: #1a237e; }
.subtitle { display: block; font-size: 28rpx; color: #666; margin-top: 10rpx; }

.card {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin: 30rpx auto;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  width: 500rpx;
  flex-shrink: 0;
  flex-grow: 0;
  box-sizing: border-box;
}

.control-header {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-bottom: 4rpx solid #1a73e8;
  padding-bottom: 10rpx;
  display: inline-block;
}

.data-row {
  display: flex;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 0.5rpx solid #eee;
  align-items: center;
  min-height: 80rpx;
  width: 100%;
  flex-shrink: 0;
}
.data-row:last-child { border-bottom: none; }

.label { font-size: 32rpx; color: #555; min-width: 80rpx; flex-shrink: 0; }
.value { font-size: 40rpx; font-weight: bold; color: #1a73e8; min-width: 120rpx; text-align: right; flex-shrink: 0;}

.footer {
  margin-top: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #ddd;
  font-size: 26rpx;
  color: #888;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.update-time { font-size: 24rpx; color: #999; }
.status { font-size: 28rpx; margin-top: 5rpx; }
.status.online { color: #4caf50; font-weight: bold; }
.status.offline { color: #9e9e9e; font-weight: bold; }

.refresh-btn {
  width: 500rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #5c6bc0, #3949ab);
  color: white;
  border-radius: 12rpx;
  font-size: 34rpx;
  margin: 40rpx auto 0;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
  flex-shrink: 0;
}
.refresh-btn::after { border: none; }
.refresh-btn:active { opacity: 0.85; }

.tip { margin-top: 20rpx; text-align: center; font-size: 26rpx; color: #999; line-height: 1.6; }

.control-switch {
  transform: scale(1.1);
}

/* ================== 红外发射小按钮（新增） ================== */
.ir-mini-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9800, #f57c00);
  box-shadow: 0 4rpx 12rpx rgba(255,152,0,0.3);
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s;
}

.ir-mini-btn:active {
  transform: scale(0.93);
  box-shadow: 0 2rpx 8rpx rgba(255,152,0,0.5);
}

.ir-mini-btn-disabled {
  background: linear-gradient(135deg, #bbb, #999);
  box-shadow: none;
  pointer-events: none;
}

.ir-mini-icon {
  font-size: 40rpx;
  line-height: 1;
}